---
import Layout from '../components/Layout.astro';
import { Image } from 'astro:assets';

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/galleries/forest-rebel/*.{jpg,jpeg,png,webp}',
  { eager: true }
);

const images = Object.entries(allImages)
  .sort(([a], [b]) => a.localeCompare(b, undefined, { numeric: true }))
  .map(([path, mod]) => mod.default);

const carousel = images.slice(0, 7);
const middle = images.slice(7, 15);
const end = images.slice(15);
---

<Layout title="Forest Rebel">
  <div class="gallery-header">
    <h1>Forest Rebel</h1>
  </div>

  <!-- Horizontal carousel: first 7 images, uncropped -->
  <div class="carousel">
    <div class="carousel-track">
      {carousel.map((img, i) => (
        <div class="carousel-slide">
          <Image
            src={img}
            alt={`Forest Rebel ${i + 1}`}
            height={500}
            format="webp"
            quality={85}
            class="carousel-img"
          />
        </div>
      ))}
    </div>
  </div>

  <div class="gallery-description">
    <p>
      Forest Rebel (2022) comprises a series of 30"x60" chromogenic prints, combinations of body photograms and monochromatic lens-based landscape scenes. The series is formed from the basic additive and subtractive color systems central to color theory (CMYK and RGB). Color darkroom process uses a CMYK mixing system; these prints were produced from black and white negatives, which were then mixed in the enlarging process using the extremities of each possible color value to showcase the widest range of color possible. These pieces engage the classic trope of landscape composition, that of the lone figure upon a vast landscape. In this case, the presence of the artist's body as a photogram signals both presence and absence, an attempted flight into nature. The artist is present in the print, present in the landscape, but in a fundamentally different way than the scene itself. Pressed against the paper, with merely a silhouette, the shadow emerges into the landscape yet does not quite reach it. The title is an homage to Ernst Junger's treatise <em>The Forest Passage</em>, a meditation on the forest as a metaphor for individual resistance from oppression. The forest rebel is the eponymous figure which retreats into the forest, cultivating an inward resistance to tyranny, manifesting in a strength of will which defies the demands of power.
    </p>
  </div>

  <!-- Middle section: images 8-15 -->
  <div class="gallery-grid">
    {middle.map((img, i) => (
      <div>
        <Image
          src={img}
          alt={`Forest Rebel ${i + 8}`}
          widths={[400, 800, 1200]}
          sizes="(max-width: 768px) 50vw, (max-width: 1200px) 33vw, 25vw"
          format="webp"
          quality={80}
          loading="lazy"
          class="gallery-image"
          data-full={img.src}
        />
      </div>
    ))}
  </div>

  <div class="gallery-description">
    <p>Forest Rebel installed in Hope College's Elevator Gallery project space, spring 2023.</p>
  </div>

  <!-- End section: images 16-20 -->
  <div class="gallery-grid">
    {end.map((img, i) => (
      <div>
        <Image
          src={img}
          alt={`Forest Rebel ${i + 16}`}
          widths={[400, 800, 1200]}
          sizes="(max-width: 768px) 50vw, (max-width: 1200px) 33vw, 25vw"
          format="webp"
          quality={80}
          loading="lazy"
          class="gallery-image"
          data-full={img.src}
        />
      </div>
    ))}
  </div>

  <div class="gallery-description">
    <p>A series of 16"x20" test prints was also produced.</p>
  </div>

  <div class="lightbox" id="lightbox">
    <div class="lightbox-close">&times;</div>
    <img src="" alt="" id="lightbox-img" />
  </div>
</Layout>

<style>
  .carousel {
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 0 1rem;
    margin-bottom: 2rem;
  }
  .carousel::-webkit-scrollbar {
    display: none;
  }
  .carousel-track {
    display: flex;
    gap: 4px;
  }
  .carousel-slide {
    flex: 0 0 auto;
  }
  .carousel-img {
    height: 50vh;
    width: auto;
    max-height: 500px;
    object-fit: contain;
    display: block;
    cursor: pointer;
  }
</style>

<script>
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;

  // Collect ALL images in page order (carousel + grids)
  const carouselImgs = Array.from(document.querySelectorAll('.carousel-img')) as HTMLImageElement[];
  const gridImgs = Array.from(document.querySelectorAll('.gallery-image')) as HTMLImageElement[];
  const allImgs = [...carouselImgs, ...gridImgs];
  const srcs = allImgs.map(img => img.dataset.full || img.src);
  let currentIndex = 0;

  function showImage(index: number) {
    currentIndex = (index + srcs.length) % srcs.length;
    lightboxImg.src = srcs[currentIndex];
    lightboxImg.alt = allImgs[currentIndex]?.alt || '';
  }

  function openLightbox(index: number) {
    showImage(index);
    lightbox?.classList.add('active');
  }

  function closeLightbox() {
    lightbox?.classList.remove('active');
  }

  // Grid clicks
  document.querySelectorAll('.gallery-grid').forEach(grid => {
    grid.addEventListener('click', (e) => {
      const img = (e.target as HTMLElement).closest('.gallery-image') as HTMLImageElement;
      if (!img) return;
      const idx = allImgs.indexOf(img);
      openLightbox(idx >= 0 ? idx : 0);
    });
  });

  // Carousel clicks
  document.querySelector('.carousel')?.addEventListener('click', (e) => {
    const img = (e.target as HTMLElement).closest('.carousel-img') as HTMLImageElement;
    if (!img) return;
    const idx = allImgs.indexOf(img);
    openLightbox(idx >= 0 ? idx : 0);
  });

  lightbox?.addEventListener('click', (e) => {
    const rect = lightboxImg.getBoundingClientRect();
    const y = e.clientY;
    // Click above or below image → close
    if (y < rect.top || y > rect.bottom) {
      closeLightbox();
      return;
    }
    // Left half of viewport → prev, right half → next
    if (e.clientX < window.innerWidth / 2) {
      showImage(currentIndex - 1);
    } else {
      showImage(currentIndex + 1);
    }
  });

  document.addEventListener('keydown', (e) => {
    if (!lightbox?.classList.contains('active')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') showImage(currentIndex - 1);
    if (e.key === 'ArrowRight') showImage(currentIndex + 1);
  });

  // Touch swipe
  let touchStartX = 0;
  let touchEndX = 0;
  lightbox?.addEventListener('touchstart', (e) => {
    touchStartX = e.changedTouches[0].screenX;
  }, { passive: true });
  lightbox?.addEventListener('touchend', (e) => {
    touchEndX = e.changedTouches[0].screenX;
    const diff = touchStartX - touchEndX;
    if (Math.abs(diff) > 50) {
      if (diff > 0) showImage(currentIndex + 1);
      else showImage(currentIndex - 1);
    }
  }, { passive: true });
</script>
