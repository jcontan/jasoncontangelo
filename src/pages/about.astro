---
import Layout from '../components/Layout.astro';
import { Image } from 'astro:assets';

const portraitImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/about/*.{jpg,jpeg,png,webp}',
  { eager: true }
);
// Prefer bobby-triune if available
const entries = Object.entries(portraitImages);
const triune = entries.find(([path]) => path.includes('bobby-triune'));
const portrait = triune ? triune[1].default : entries[0]?.[1]?.default;
---

<Layout title="About">
  <div class="about-container">
    <div class="about-portrait">
      {portrait ? (
        <Image
          src={portrait}
          alt="Jason Contangelo"
          width={500}
          format="webp"
          quality={85}
        />
      ) : (
        <div style="width:400px;height:500px;background:#1a1a1a;"></div>
      )}
    </div>

    <div class="about-text">
      <h2>About</h2>

      <p>
        Jason Contangelo (b. 1992, Buffalo, NY) is an experimental photographer.
        He completed his BA at the University of Michigan (2014), and his MFA at
        the University at Buffalo (2021). He taught photography for two years at
        Hope College in Holland, Michigan, and is now an independent artist and
        art director based in Tonawanda, NY.
      </p>

      <p>
        As Bobby Mars, Contangelo currently serves as the Art Director of the
        Michigan Enjoyer, and CEO of his own art direction firm BobbyCorp LLC.
      </p>

      <p>
        His work has been exhibited at University at Buffalo Galleries, CEPA
        Gallery (Buffalo), De Pree Gallery (Holland, MI), and BOX Gallery
        (Buffalo), Fitz Books (Buffalo), and Black Rock Arts (Buffalo), among
        others.
      </p>

      <h2 style="margin-top: 2rem;">Artist Statement</h2>

      <p>
        Through analog photographic methods, Contangelo explores spirituality
        and psychology through abstracted landscapes and unconventional
        portraiture. He eschews realistic representation in favor of photographs
        that subvert their very ties to reality through entropy, chaos, and
        visual process artifacts.
      </p>

      <div class="about-contact">
        <a href="mailto:jason@jasoncontangelo.com">jason@jasoncontangelo.com</a>
        <a href="https://instagram.com/jasoncontangelo" target="_blank" rel="noopener">
          @jasoncontangelo
        </a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .about-container {
    max-width: 700px;
    margin: 0 auto;
    padding: 6rem 2rem 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
  }

  .about-portrait {
    width: 100%;
    text-align: center;
  }

  .about-portrait img {
    width: 100%;
    max-width: 500px;
    height: auto;
    margin: 0 auto;
  }

  .about-text {
    width: 100%;
  }

  .about-text h2 {
    font-size: 1.4rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .about-text p {
    font-size: 0.9rem;
    line-height: 1.8;
    color: #ccc;
    margin-bottom: 1em;
  }

  .about-contact {
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .about-contact a {
    font-size: 0.85rem;
    color: #ccc;
    text-decoration: underline;
  }
</style>
