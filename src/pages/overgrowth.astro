---
import Layout from '../components/Layout.astro';
import { Image } from 'astro:assets';

const base = import.meta.env.BASE_URL;

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/galleries/overgrowth/*.{jpg,jpeg,png,webp}',
  { eager: true }
);

const images = Object.entries(allImages)
  .sort(([a], [b]) => a.localeCompare(b, undefined, { numeric: true }))
  .map(([path, mod]) => mod.default);

const main = images.slice(0, 37);
const end = images.slice(37);
---

<Layout title="Overgrowth">
  <div class="gallery-header">
    <h1>Overgrowth</h1>
  </div>

  <!-- First 37 images -->
  <div class="gallery-grid">
    {main.map((img, i) => (
      <div>
        <Image
          src={img}
          alt={`Overgrowth ${i + 1}`}
          widths={[400, 800, 1200]}
          sizes="(max-width: 768px) 50vw, (max-width: 1200px) 33vw, 25vw"
          format="webp"
          quality={80}
          loading={i < 8 ? 'eager' : 'lazy'}
          class="gallery-image"
          data-full={img.src}
        />
      </div>
    ))}
  </div>

  <div class="gallery-description">
    <p>
      Overgrowth (2020) was presented as my MFA thesis project at the University at Buffalo. A series of 20"x24" chromogenic prints, the work is concerned with an expanded view of the landscape beyond limited human perspective. Engaging with photographic process as a means to expand perception, these scenes at once transcend human egotism, while placing it as distinctly centered within our experience of nature. You can read the full text of the written thesis <a href={`${base}overgrowth-thesis.pdf`} target="_blank" rel="noopener">here</a>.
    </p>
  </div>

  <!-- Last 8 images -->
  <div class="gallery-grid">
    {end.map((img, i) => (
      <div>
        <Image
          src={img}
          alt={`Overgrowth ${i + 38}`}
          widths={[400, 800, 1200]}
          sizes="(max-width: 768px) 50vw, (max-width: 1200px) 33vw, 25vw"
          format="webp"
          quality={80}
          loading="lazy"
          class="gallery-image"
          data-full={img.src}
        />
      </div>
    ))}
  </div>

  <div class="gallery-description">
    <p>Overgrowth was exhibited at CEPA Gallery in Buffalo, NY in the spring of 2021. Documentation above.</p>
  </div>

  <div class="lightbox" id="lightbox">
    <div class="lightbox-close">&times;</div>
    <img src="" alt="" id="lightbox-img" />
  </div>
</Layout>

<script>
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;

  const allImgs = Array.from(document.querySelectorAll('.gallery-image')) as HTMLImageElement[];
  const srcs = allImgs.map(img => img.dataset.full || img.src);
  let currentIndex = 0;

  function showImage(index: number) {
    currentIndex = (index + srcs.length) % srcs.length;
    lightboxImg.src = srcs[currentIndex];
    lightboxImg.alt = allImgs[currentIndex]?.alt || '';
  }

  function openLightbox(index: number) {
    showImage(index);
    lightbox?.classList.add('active');
  }

  function closeLightbox() {
    lightbox?.classList.remove('active');
  }

  document.querySelectorAll('.gallery-grid').forEach(grid => {
    grid.addEventListener('click', (e) => {
      const img = (e.target as HTMLElement).closest('.gallery-image') as HTMLImageElement;
      if (!img) return;
      const idx = allImgs.indexOf(img);
      openLightbox(idx >= 0 ? idx : 0);
    });
  });

  lightbox?.addEventListener('click', (e) => {
    const rect = lightboxImg.getBoundingClientRect();
    const y = e.clientY;
    if (y < rect.top || y > rect.bottom) {
      closeLightbox();
      return;
    }
    if (e.clientX < window.innerWidth / 2) {
      showImage(currentIndex - 1);
    } else {
      showImage(currentIndex + 1);
    }
  });

  document.addEventListener('keydown', (e) => {
    if (!lightbox?.classList.contains('active')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') showImage(currentIndex - 1);
    if (e.key === 'ArrowRight') showImage(currentIndex + 1);
  });

  let touchStartX = 0;
  let touchEndX = 0;
  lightbox?.addEventListener('touchstart', (e) => {
    touchStartX = e.changedTouches[0].screenX;
  }, { passive: true });
  lightbox?.addEventListener('touchend', (e) => {
    touchEndX = e.changedTouches[0].screenX;
    const diff = touchStartX - touchEndX;
    if (Math.abs(diff) > 50) {
      if (diff > 0) showImage(currentIndex + 1);
      else showImage(currentIndex - 1);
    }
  }, { passive: true });
</script>
