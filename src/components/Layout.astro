---
import '../styles/global.css';
import Nav from './Nav.astro';

interface Props {
  title?: string;
}

const { title = 'Jason Contangelo' } = Astro.props;
const pageTitle = title === 'Jason Contangelo' ? title : `${title} — Jason Contangelo`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Photography by Jason Contangelo" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
  </body>
</html>
