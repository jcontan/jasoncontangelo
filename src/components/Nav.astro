---
import { getCollection } from 'astro:content';

const galleries = await getCollection('galleries');
const sortedGalleries = galleries.sort((a, b) => a.data.order - b.data.order);
const base = import.meta.env.BASE_URL;
---

<nav class="site-nav">
  <a href={base} class="site-name">Jason Contangelo</a>

  <div class="work-pill-wrapper">
    <button class="work-pill" id="work-pill">Work</button>
    <div class="work-dropdown" id="work-dropdown">
      {sortedGalleries.map((gallery) => (
        <a href={`${base}${gallery.id}`} class="work-dropdown-item">
          {gallery.data.title}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const pill = document.getElementById('work-pill');
  const dropdown = document.getElementById('work-dropdown');
  let isOpen = false;

  function toggle() {
    isOpen = !isOpen;
    dropdown?.classList.toggle('active', isOpen);
    pill?.classList.toggle('active', isOpen);
  }

  function close() {
    isOpen = false;
    dropdown?.classList.remove('active');
    pill?.classList.remove('active');
  }

  pill?.addEventListener('click', (e) => {
    e.stopPropagation();
    toggle();
  });

  document.addEventListener('click', (e) => {
    if (isOpen && !dropdown?.contains(e.target as Node)) {
      close();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') close();
  });
</script>
